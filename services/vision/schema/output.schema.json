{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scry.local/schema/vision-count-output.json",
  "title": "Scry count-line output",
  "type": "object",
  "additionalProperties": false,
  "required": ["count", "events"],
  "properties": {
    "count": { "type": "integer", "minimum": 0 },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["track_id", "timestamp", "direction", "category", "confidence"],
        "properties": {
          "track_id": { "type": "string", "minLength": 1 },
          "timestamp": { "type": "string", "format": "date-time" },
          "direction": { "enum": ["positive_to_negative", "negative_to_positive"] },
          "category": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
