{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scry.local/schema/vision-count-input.json",
  "title": "Scry tracked-centroid count input",
  "type": "object",
  "additionalProperties": false,
  "required": ["line", "samples"],
  "properties": {
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "$ref": "#/$defs/point" },
        "end": { "$ref": "#/$defs/point" },
        "acceptedDirection": { "type": ["string", "null"], "enum": ["positive_to_negative", "negative_to_positive", null] }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimumConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "acceptedCategories": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "deadbandDistance": { "type": "number", "minimum": 0 },
        "staleTrackSeconds": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "samples": { "type": "array", "items": { "$ref": "#/$defs/sample" } }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trackId", "timestamp", "centroid", "confidence", "category"],
      "properties": {
        "trackId": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "centroid": { "$ref": "#/$defs/point" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "category": { "type": "string", "minLength": 1 }
      }
    }
  }
}
